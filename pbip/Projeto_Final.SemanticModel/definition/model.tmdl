model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Transformar Arquivo de Arquivos Brutos'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transformar Arquivo de Arquivos Brutos\Consultas Auxiliares'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Arquivos Brutos","Fato_Clima","Arquivo de Amostra","Parâmetro1","Transformar o Arquivo de Exemplo","Transformar Arquivo"]

annotation PBI_ProTooling = ["DevMode"]

ref table Fato_Clima
ref table DimCalendario
ref table DimHorario
ref table DimEstacao
ref table Medidas

ref role 'Gerente Regional'
ref role Diretoria

ref cultureInfo pt-BR

