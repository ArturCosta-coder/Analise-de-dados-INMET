		annotation SummarizationSetBy = Automatic

	partition DimCalendario = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    CALENDAR ( MIN ( Fato_Clima[Data] ), MAX ( Fato_Clima[Data] ) ),
				    "Ano", YEAR ( [Date] ),
				    "MesNumero", MONTH ( [Date] ),
				    "Mes", FORMAT ( [Date], "MMMM" ),
				    "MesAbrev", FORMAT ( [Date], "MMM" ),
				    "Trimestre", "T" & FORMAT ( [Date], "Q" ),
				    "Dia", DAY ( [Date] ),
				    "DiaSemanaNumero", WEEKDAY ( [Date], 2 ),
				    "DiaSemana", FORMAT ( [Date], "dddd" ),
				    "SemanaAno", WEEKNUM ( [Date], 2 )
				)

	annotation PBI_Id = d2db64aa705b4597ab490fdf6030bf6e

